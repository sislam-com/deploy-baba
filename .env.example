# deploy-baba — Environment Variables
#
# Copy to .env and fill in values for local development.
# `just dev-env` auto-populates most of these from AWS SSM/SM.
#
# SECRETS POLICY: All secret values must live in AWS Secrets Manager.
# This file should NEVER contain real keys, passwords, or tokens.
# See plans/modules/secrets-manager.md for the full policy.

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=deploy-baba.db

# ── Authentication (Cognito) ─────────────────────────────────────────────────
# Fetched from SSM Parameter Store by `just dev-env`.
# Leave empty to enable dev-mode auth bypass.
COGNITO_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=
COGNITO_REGION=us-east-1
COGNITO_JWKS=
APP_DOMAIN=http://localhost:3000

# ── LLM / RAG ───────────────────────────────────────────────────────────────
# Anthropic API key — loaded from Secrets Manager via ARN.
# SM secret: deploy-baba/prod/anthropic-api-key (production)
# SM secret: root-anthropic-access-key (local dev)
ANTHROPIC_API_KEY_ARN=
ANTHROPIC_API_KEY=

# Feature flag: set to "1" to enable POST /api/ask
RAG_PUBLIC_ENABLED=1

# Rate limit for /api/ask (requests per minute per IP)
ASK_RATE_LIMIT=10

# Lambda function name for the non-VPC LLM proxy (production only).
# When unset, the UI service calls Anthropic directly (local dev path).
LLM_PROXY_LAMBDA_NAME=

# Base URL for portfolio API tool callbacks (agentic mode).
# In production: the UI Lambda's function URL.
# Locally: http://localhost:3001 (API server port)
PORTFOLIO_API_BASE_URL=http://localhost:3001

# ── Contact Form / PoW ──────────────────────────────────────────────────────
# SM secret: deploy-baba/prod/pow-secret
# Falls back to a dev default when unset locally.
POW_SECRET_ARN=

# Email Lambda function name
EMAIL_LAMBDA_NAME=deploy-baba-email

# ── Email (SES) — services/email Lambda ──────────────────────────────────────
# SM secret: deploy-baba/prod/ses-config (JSON: from, ack_from, to)
SES_FROM_EMAIL=
SES_ACK_FROM_EMAIL=
CONTACT_TO_EMAIL=

# ── S3 / Storage ─────────────────────────────────────────────────────────────
S3_BACKUP_BUCKET=

# ── SPA Deploy (xtask) ──────────────────────────────────────────────────────
# SM secret: deploy-baba/prod/deploy-config (JSON: spa_bucket, cloudfront_id, ui_fn_name, fn_url)
# These are auto-populated from `just infra-apply` outputs.
SPA_BUCKET=
UI_FN_NAME=
FN_URL=
CLOUDFRONT_ID=

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_PROFILE=default

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info
